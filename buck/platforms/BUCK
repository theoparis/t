load(":defs.bzl", "generate_platforms", "default_platforms")

generate_platforms(default_platforms)

[
    platform(
        name = f'{arch}-{name}',
        deps = [ ':default' ],
        constraint_values = [
            f'prelude//cpu/constraints:{arch}',
            f'prelude//os/constraints:{name}',
        ],
    ) for name in [ 'linux-gnu', 'uefi', 'none' ]
      for arch in [ 'arm64', 'x86_64' ]
      if not (arch == 'x86_64' and name == 'none')
]
